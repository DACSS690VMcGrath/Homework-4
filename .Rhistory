setwd("~/GitHub/Homework-4")
library(flexdashboard)
#---load packages-----
pacman::p_load(tidyverse, dplyr, readr, stringr,
readxl, lubridate, ggplot2, magrittr,
rio, reshape2, polycor, BBmisc)
#--- Cat Cat Ma Arrests-----
#"C:\Users\patri\OneDrive\Desktop\DACSS\DACSS690V\Week_4_HW\Mass_Arrests.xlsx"
#change to read off github - https://github.com/DACSS690VMcGrath/Homework-4/raw/main/Mass_Arrests.xlsx
#ma_arrests <- read_xlsx("C:/Users/patri/OneDrive/Desktop/DACSS/DACSS690V/Week_4_HW/Mass_Arrests.xlsx", sheet = "MSP DFS Arrests")
ma_arrests <- import("https://github.com/DACSS690VMcGrath/Homework-4/raw/main/Mass_Arrests.xlsx", sheet = "MSP DFS Arrests")
ma_arrest_table = table(ma_arrests$Race, ma_arrests$`Arrest Type`)
#View(ma_arrests)
ma_arrest_prct_table=prop.table(ma_arrest_table,
margin = 2)%>%round(.,3)
#making a data frame from the contingency table
ma_arrest_df=as.data.frame(ma_arrest_table)
names(ma_arrest_df)=c("Race","Arrest","Count")
#adding marginal shares as percentages:
ma_arrest_df$pctCol=100*as.data.frame(ma_arrest_prct_table)[,3]
#clean ma_arrest_df to include full variable names
bar_order <- c("O", "F", "M", "W")
ma_arrest_df$Arrest <- factor(ma_arrest_df$Arrest, levels = bar_order)
base1 = ggplot(data=ma_arrest_df,
aes(x=reorder(Race, pctCol), y=pctCol,
fill=Arrest)) + geom_bar(stat="identity", position = "dodge")
#x-axis Race, y-axis Pct col - percent of arrests by Race - filled by Arrest type
#E69F00, #56B4E9, #009E73, #F0E442, #0072B2, #D55E00
arrest_plot <- base1 + scale_fill_manual(name = "Arrest Categories",
breaks = c("W", "M", "F", "O"),
labels = c("O" = "Other", "M" = "Misdemeanor", "F" = "Felony", "W" = "Warrant"),
values = c("W" = "#E69F00",
"M" = "#56B4E9",
"F" = "#009E73",
"O" = "#F0E442"))+
labs(
#title = "Arrest Types Composition are largely Consistent Within Racial Groups",
subtitle = "Hispanic Individuals Account for the Majority of Arrests Across Categories",
x = (""),
y = "",
caption = "Source: MSP DFS"
) +
scale_x_discrete(labels = c("H" = "Hispanic/\nLatino",
"W" = "White",
"B" = "Black/\nAfrican American",
"O" = "Asian/\nPacific Islander",
"J" = "Middle Eastern/\nEast Indian",
"U" = "Unknown",
"I" = "American Indian/\nAlaskan Native"
)) +
coord_flip() +
theme_minimal() +
theme(panel.grid = element_blank())+
geom_text(
aes(
label = paste0(round(pctCol, 1), "%"),
hjust = ifelse(pctCol < 5.1,
-0.2,
.95)
),
position = position_dodge(width = 0.9),
size = 3
)+ theme(#axis.title.x = element_blank(),
axis.text.x = element_blank(),
axis.ticks.x = element_blank()) +
theme(axis.text.y = element_text(hjust = 0, face = "bold")) +
theme(#plot.title = element_text(hjust = 0),
plot.title.position = "plot",
#plot.subtitle = element_text(hjust = 0)
)
#save plot
saveRDS(arrest_plot, file = "arrest_plot.rds")
#---Num Num Covid-19----
#"C:\Users\patri\OneDrive\Desktop\DACSS\DACSS690V\Week_4_HW\covid-19.csv"
#https://github.com/DACSS690VMcGrath/Homework-4/raw/main/covid-19.csv
#covid <- read_csv("C:/Users/patri/OneDrive/Desktop/DACSS/DACSS690V/Week_4_HW/covid-19.csv")
covid <- import("https://github.com/DACSS690VMcGrath/Homework-4/raw/main/covid-19.csv")
#colnames(covid)
#View(covid)
#group data by year and plot over time?
covid <- covid %>%
mutate(death_case_ratio = ifelse(daily_cases_mean > 0,
daily_deaths_mean / daily_cases_mean,
NA
))
covid_us <- covid |>
filter(
!is.na(death_case_ratio),
!is.infinite(death_case_ratio),
daily_cases_mean > 0
) |>
filter(Entity =="United States" | Entity == "United States Vigin Islands")
year_starts <- as.Date(c(#"2020-01-01",
"2021-01-01", "2022-01-01",
"2023-01-01", "2024-01-01"))
#match year and line color
year_colors <- scales::hue_pal()(5)
names(year_colors) <- c("2020", "2021", "2022", "2023", "2024")
peaks <- covid_us %>%
group_by(year) %>%
slice_max(death_case_ratio, n = 1) %>%
ungroup()
#--plot--
covid_plot <- ggplot(covid_us, aes(x = as.Date(date, "%m/%d/%y"), y = death_case_ratio,
color = factor(year))) +
geom_vline(xintercept = year_starts, color = "gray60", linewidth = 0.4, linetype = "dotted") +
geom_line() +
labs(
#title = "Daily COVID-19 Death-to-Case Ratio by Year in US",
subtitle = "Death-to-Case Ratio peaked in Early-2020 then progressively dropped",
x = "",
y = "Deaths per Case",
color = "Year"
) +
scale_y_continuous(labels = scales::percent, expand = c(0.01, 0)) +
coord_cartesian(ylim = c(0, max(covid_us$death_case_ratio, na.rm = TRUE) * 1.1)) +
theme(legend.position = "none") +
#theme(panel.grid = element_blank()) +
theme(panel.background = element_rect(fill = "white", colour = "black")) +
scale_x_date(breaks = as.Date(c("2020-01-01", "2021-01-01", "2022-01-01",
"2023-01-01", "2024-01-01")),
date_labels = "%Y") +
theme(axis.text.x = element_text(color = year_colors, face = "bold", size = 10)) +
theme(axis.text.y = element_text(face = "bold", size = 10)) +
geom_point(data = peaks,
aes(x = as.Date(date, "%m/%d/%y"), y = death_case_ratio),
size = 2) +
geom_text(data = peaks,
aes(x = as.Date(date, "%m/%d/%y"), y = death_case_ratio,
label = paste0(round(death_case_ratio * 100, 1), "%")),
hjust = -.2,
size = 3,
show.legend = FALSE)
saveRDS(covid_plot, file = "covid_plot.rds")
#---Num Cat Ma Arrests ----
#something with Age - Age is the only numerical column
#Lollipop chart with min, mean, and max age?
ma_arrest_age <- ma_arrests |> filter(!is.na(Age))
plotdata <- ma_arrest_age |>
group_by(Race) |>
summarize(
mean_age = mean(Age),
min_age  = min(Age),
max_age  = max(Age)
)|>
mutate(range = max_age - min_age)
num_cat_plot <- ggplot(plotdata, aes(x = reorder(Race, range), y = mean_age)) +
geom_segment(aes(x = reorder(Race, range), xend = reorder(Race, range),
y = min_age, yend = max_age), color = "black") +
geom_point(aes(y = min_age, color = "Min"), size = 3) +
geom_point(aes(y = max_age, color = "Max"), size = 3) +
geom_point(aes(y = mean_age, color = "Mean"), size = 3) +
geom_text(aes(y = min_age, label = round(min_age, 1)),
color = "darkgreen", size = 3, vjust = -1) +
geom_text(aes(y = max_age, label = round(max_age, 1)),
color = "coral", size = 3, vjust = 2) +
geom_text(aes(y = mean_age, label = round(mean_age, 1)),
color = "steelblue", size = 3, vjust = -1) +
scale_color_manual(
name = "Age Statistics",
values = c("Min" = "darkgreen", "Max" = "coral", "Mean" = "steelblue")
) +
scale_x_discrete(labels = c("H" = "Hispanic/\nLatino",
"W" = "White",
"B" = "Black/\nAfrican American",
"O" = "Asian/\nPacific Islander",
"J" = "Middle Eastern/\nEast Indian",
"U" = "Unknown",
"I" = "American Indian/\nAlaskan Native"
)) +
coord_flip() +
labs(x = "", y = "Age") +
theme_classic() +
labs(
#title = "Distribution of Ages of Racial Groups",
subtitle = "White and Hispanic/Latino had nearly identical arrest age distribution"
)+
theme(axis.text.y = element_text(hjust = 0, face = "bold")) + theme(axis.title.x = element_blank(),
axis.text.x = element_blank(),
axis.ticks.x = element_blank())+
theme(
panel.border = element_blank(),
plot.background = element_blank(),
axis.line = element_blank()
) +
theme(plot.title.position = "plot")
saveRDS(num_cat_plot, "num_cat_plot.rds")
